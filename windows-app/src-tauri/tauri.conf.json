{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "LocalDrop",
  "version": "0.1.0",
  "identifier": "com.localdrop.app",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "LocalDrop – LAN File Transfer",
        "width": 1000,
        "height": 620,
        "minWidth": 700,
        "minHeight": 460,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installerIcon": "icons/icon.ico"
      }
    }
  }
}
